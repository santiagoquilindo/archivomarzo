{
  "name": "gestion-documental-electron",
  "version": "1.0.0",
  "description": "Base local desktop app para gestión documental (Electron + Express + SQLite)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "init-db": "node backend/src/db/init.js",
    "start-api": "node backend/src/server.js",
    "audit-db": "node scripts/audit-database.js",
    "package": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "electron": "^26.2.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron-builder": "^24.4.0"
  },
  "build": {
    "appId": "com.example.gestiondocumental",
    "productName": "GestionDocumental",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
