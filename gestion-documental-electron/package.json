{
  "name": "gestion-documental-electron",
  "version": "1.0.0",
  "description": "Base local desktop app para gestión documental (Electron + Express + SQLite)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "init-db": "node backend/src/db/init.js",
    "start-api": "node backend/src/server.js",
    "audit-db": "node scripts/audit-database.js",
    "classify-docs": "node scripts/classify-documents.js",
    "classify-docs:v2": "node scripts/classify-documents-v2.js",
    "sanitization:dry-run": "node scripts/simulate-sanitization-dry-run.js",
    "sanitization:run": "node scripts/run-sanitization.js",
    "package": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^26.2.0",
    "electron-builder": "^24.4.0"
  },
  "build": {
    "appId": "co.sagcauca.gestiondocumental",
    "productName": "Gestion Documental SAG Cauca",
    "artifactName": "Gestion-Documental-SAG-Cauca-Setup-${version}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "npmRebuild": false,
    "files": [
      "backend/**/*",
      "build/icon.ico",
      "electron/**/*",
      "frontend/**/*",
      "package.json",
      "!data/**/*",
      "!reports/**/*",
      "!test_docs/**/*",
      "!scripts/**/*",
      "!*.db",
      "!*.sqlite",
      "!*.sqlite3",
      "!*.log"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gestion Documental SAG Cauca",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "allowElevation": false
    }
  }
}
